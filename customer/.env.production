# Customer App — Production
# VITE_API_URL must be the full API URL. The Vite proxy only works in dev;
# production static files are served from https://dealmachan.com and the API
# is a separate origin (https://api.dealmachan.com), so CORS applies.
VITE_API_URL=https://api.dealmachan.com/api
VITE_API_ORIGIN=https://api.dealmachan.com
VITE_APP_NAME=Deal Machan
VITE_SUPPORT_EMAIL=support@dealmachan.com
