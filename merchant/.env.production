# DealMachan Merchant App — Production Environment
# Override these values for your production server.

# Full URL of the API server (no trailing slash)
# Example: https://api.dealmachan.com/api
VITE_API_URL=https://api.dealmachan.com/api

# API origin — used to build image URLs (no /api suffix, no trailing slash)
VITE_API_ORIGIN=https://api.dealmachan.com

# App metadata
VITE_APP_NAME="DealMachan Merchant"
VITE_APP_VERSION="1.0.0"
